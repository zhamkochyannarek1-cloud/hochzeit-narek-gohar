<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<title>Narek & Gohar – Hochzeit</title>

<style>
body {
  margin: 0;
  font-family: Georgia, serif;
  background: #f6f3ee;
  color: #2b2b2b;
  text-align: center;
}

.container {
  max-width: 900px;
  margin: 60px auto;
  padding: 50px;
  background: white;
  border-radius: 14px;
  box-shadow: 0 15px 50px rgba(0,0,0,0.08);
}

h1 {
  font-size: 46px;
  font-weight: normal;
  letter-spacing: 3px;
  margin-bottom: 5px;
}

.divider {
  width: 90px;
  height: 2px;
  background: linear-gradient(to right, #c9a96a, #9f7c3f);
  margin: 20px auto 30px;
}

.text {
  font-size: 18px;
  line-height: 1.6;
}

.highlight {
  font-size: 22px;
  margin: 15px 0;
}

.countdown {
  font-size: 26px;
  margin: 30px 0;
  letter-spacing: 1px;
}

.gallery {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px,1fr));
  gap: 15px;
  margin-top: 40px;
}

.gallery img {
  width: 100%;
  height: 260px;
  object-fit: cover;
  border-radius: 10px;
}

.form {
  margin-top: 40px;
  text-align: left;
}

input, select, textarea {
  width: 100%;
  padding: 12px;
  margin-top: 8px;
  margin-bottom: 18px;
  border-radius: 8px;
  border: 1px solid #ccc;
  font-family: Georgia, serif;
  font-size: 15px;
}

button {
  background: linear-gradient(to right, #c9a96a, #9f7c3f);
  color: white;
  padding: 14px;
  border: none;
  border-radius: 10px;
  font-size: 16px;
  cursor: pointer;
  width: 100%;
}

button:hover {
  opacity: 0.9;
}

.footer {
  margin-top: 40px;
  font-style: italic;
}
</style>
</head>

<body>

<div class="container">

<h1>Narek & Gohar</h1>
<div class="divider"></div>

<p class="text">
Mit Freude im Herzen laden wir euch ein,<br>
unseren Hochzeitstag gemeinsam mit uns zu feiern.
</p>

<div class="highlight">
📍 Simmertal<br>
📅 15.08.2026 — Beginn 15:00 Uhr
</div>

<div class="countdown" id="countdown"></div>

<!-- Galerie -->
<h2>Unsere Momente</h2>
<div class="gallery">
  <img src="bild1.jpg">
  <img src="bild2.jpg">
  <img src="bild3.jpg">
</div>

<!-- RSVP -->
<h2>Teilnahme bestätigen</h2>

<form class="form">
<label>Name</label>
<input type="text" placeholder="Dein Name">

<label>Anzahl Personen</label>
<select>
<option>1</option>
<option>2</option>
<option>3</option>
<option>4</option>
</select>

<label>Nachricht</label>
<textarea rows="4" placeholder="Optional"></textarea>

<button type="submit">Zusage senden</button>
</form>

<div class="footer">
Wir freuen uns, diesen Tag mit euch zu teilen.
</div>

</div>

<script>
const targetDate = new Date("Aug 15, 2026 15:00:00").getTime();

const x = setInterval(function() {
  const now = new Date().getTime();
  const diff = targetDate - now;

  const days = Math.floor(diff / (1000*60*60*24));
  const hours = Math.floor((diff % (1000*60*60*24)) / (1000*60*60));
  const minutes = Math.floor((diff % (1000*60*60)) / (1000*60));
  const seconds = Math.floor((diff % (1000*60)) / 1000);

  document.getElementById("countdown").innerHTML =
    "Countdown: " + days + " Tage " + hours + " Std " +
    minutes + " Min " + seconds + " Sek";

  if (diff < 0) {
    clearInterval(x);
    document.getElementById("countdown").innerHTML = "Heute ist der große Tag!";
  }
}, 1000);
</script>

</body>
</html>
